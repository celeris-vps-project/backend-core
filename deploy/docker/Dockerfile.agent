# ── Builder ────────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS builder

ARG VERSION=dev
ARG TARGETOS=linux
ARG TARGETARCH=amd64

RUN apk add --no-cache git

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .

RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -trimpath \
    -ldflags="-s -w -X main.version=${VERSION}" \
    -o /out/celeris-agent ./cmd/agent

# ── Runtime ────────────────────────────────────────────────────────────
FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /out/celeris-agent /usr/local/bin/celeris-agent
COPY agent.example.yaml /etc/celeris/agent.yaml

ENTRYPOINT ["celeris-agent"]
CMD ["-config", "/etc/celeris/agent.yaml"]
